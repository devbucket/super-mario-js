{
  "name": "super-mario-js",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "check": "npm run lint && npm run format:check && npm run build",
    "lint": "eslint --cache . && biome check --formatter-enabled=false .",
    "lint:fix": "eslint --fix --cache . && biome check --write .",
    "lint:staged": "lint-staged -q",
    "prepare": "husky",
    "format": "biome format --write .",
    "format:check": "biome ci --linter-enabled=false --assist-enabled=false ."
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx}": [
      "eslint --fix --cache",
      "biome check --write --no-errors-on-unmatched"
    ],
    "**/*.{json,css}": [
      "biome format --write --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.46.0",
    "vite": "^8.0.11"
  }
}
